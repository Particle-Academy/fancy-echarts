{
  "name": "@particle-academy/fancy-echarts",
  "version": "2.0.1",
  "description": "React component library wrapping Apache ECharts with typed components for every chart type",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-echarts.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-echarts#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-echarts/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "react",
    "echarts",
    "charts",
    "visualization",
    "components"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "echarts": "^5.5.0",
    "echarts-gl": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "echarts-gl": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "echarts": "^5.6.0",
    "echarts-gl": "^2.0.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
